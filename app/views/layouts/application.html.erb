<!DOCTYPE html>
<html>
  <head>
    <title>Furitsumu</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app-shell">
      <header class="app-header">
        <%= link_to root_path, class: "brand-mark" do %>
          <span class="brand-mark-dot"></span>
          <span>Furitsumu</span>
        <% end %>

        <nav class="flex flex-wrap items-center justify-end gap-2 text-sm text-slate-300">
          <% if user_signed_in? %>
            <span class="hidden text-sm text-slate-300 sm:inline"><%= current_user.name %></span>
            <%= link_to "一覧", entries_path, class: "nav-link" %>
            <%= link_to "Insights", insight_path, class: "nav-link" %>
            <%= link_to "録音する", new_entry_path, class: "nav-link-primary" %>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "nav-link" %>
          <% else %>
            <%= link_to "ログイン", new_user_session_path, class: "nav-link" %>
            <%= link_to "はじめる", new_user_registration_path, class: "nav-link-primary" %>
          <% end %>
        </nav>
      </header>

      <main class="page-wrap">
        <% if notice.present? || alert.present? %>
          <div class="mb-6 space-y-3">
            <% if notice.present? %>
              <div class="notice-card notice-card-success"><%= notice %></div>
            <% end %>
            <% if alert.present? %>
              <div class="notice-card notice-card-warning"><%= alert %></div>
            <% end %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
