<%= turbo_stream_from @entry %>

<section class="space-y-6 py-6">
  <div class="hero-surface">
    <div class="grid gap-6 px-8 py-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div class="space-y-3">
          <p class="eyebrow">Reflection</p>
          <p class="text-sm text-slate-500"><%= l(@entry.recorded_on, format: :long) %></p>
          <h1 class="section-title"><%= @entry.summary.presence || "今日の振り返り" %></h1>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <span class="<%= entry_status_badge_classes(@entry) %>"><%= entry_status_label(@entry) %></span>
          <%= link_to "一覧へ戻る", entries_path, class: "secondary-button" %>
        </div>
      </div>

      <%= render "entries/details", entry: @entry %>
    </div>
  </div>
</section>
