<%= turbo_stream_from @entry %>

<section class="space-y-6 py-6">
  <div class="rounded-[2rem] bg-white p-8 text-slate-900 shadow-xl shadow-slate-950/10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm text-slate-500"><%= l(@entry.recorded_on, format: :long) %></p>
        <h1 class="mt-2 text-3xl font-semibold"><%= @entry.summary.presence || "今日の振り返り" %></h1>
      </div>
      <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
        <%= @entry.status.humanize %>
      </span>
    </div>

    <%= render "entries/details", entry: @entry %>
  </div>

  <div class="flex justify-end">
    <%= link_to "一覧へ戻る", entries_path,
          class: "text-sm text-slate-400 underline decoration-slate-300 underline-offset-4 hover:text-slate-600" %>
  </div>
</section>
