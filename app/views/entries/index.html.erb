<section class="space-y-8 py-6">
  <div class="flex flex-col gap-4 rounded-[2rem] bg-white p-8 text-slate-900 shadow-xl shadow-slate-950/10 lg:flex-row lg:items-end lg:justify-between">
    <div class="space-y-3">
      <p class="text-xs tracking-[0.24em] text-slate-500 uppercase">Dashboard</p>
      <h1 class="text-3xl font-semibold">今日の振り返りを、静かに積む。</h1>
      <p class="max-w-2xl text-sm leading-7 text-slate-600">
        1 日 1 エントリーだけに絞ることで、迷わず続けられる設計にしています。
      </p>
    </div>

    <% if @today_entry.present? %>
      <div class="rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4">
        <p class="text-sm text-slate-500">今日は記録済みです</p>
        <%= link_to "今日のエントリーを見る", @today_entry, class: "mt-2 inline-flex text-sm font-medium text-slate-900 underline decoration-slate-300 underline-offset-4" %>
      </div>
    <% else %>
      <%= link_to "今日を振り返る", new_entry_path, class: "inline-flex items-center justify-center rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" %>
    <% end %>
  </div>

  <div class="space-y-4">
    <% if @entries.any? %>
      <% @entries.each do |entry| %>
        <%= link_to entry_path(entry), class: "block rounded-[1.75rem] border border-slate-200 bg-white p-6 transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg hover:shadow-slate-950/5" do %>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-2">
              <p class="text-sm text-slate-500"><%= l(entry.recorded_on, format: :long) %></p>
              <p class="text-lg font-medium text-slate-900"><%= entry.summary.presence || "まだ要約はありません" %></p>
              <p class="text-sm leading-7 text-slate-600">
                <%= truncate(entry.transcript.presence || "録音した音声と振り返りの中身がここに並びます。", length: 120) %>
              </p>
            </div>

            <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium <%= entry.completed? ? "bg-emerald-100 text-emerald-800" : "bg-slate-100 text-slate-600" %>">
              <%= entry.status.humanize %>
            </span>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="rounded-[1.75rem] border border-dashed border-slate-300 bg-white/80 p-10 text-center text-slate-600">
        まだ振り返りはありません。最初の 3 分をここから始めましょう。
      </div>
    <% end %>
  </div>
</section>
