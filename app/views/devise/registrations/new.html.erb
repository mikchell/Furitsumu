<section class="mx-auto w-full max-w-xl rounded-[2rem] bg-white p-8 text-slate-900 shadow-xl shadow-slate-950/10">
  <div class="space-y-3">
    <p class="text-xs tracking-[0.24em] text-slate-500 uppercase">Create account</p>
    <h1 class="text-3xl font-semibold">Furitsumu を始める</h1>
    <p class="text-sm leading-7 text-slate-600">まずはアカウントを作って、今日の 3 分を積み始めましょう。</p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-2">
      <%= f.label :name, "表示名", class: "text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-slate-400" %>
    </div>

    <div class="space-y-2">
      <%= f.label :email, class: "text-sm font-medium text-slate-700" %>
      <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-slate-400" %>
    </div>

    <%= f.hidden_field :timezone, value: resource.timezone.presence || "Asia/Tokyo" %>

    <div class="space-y-2">
      <%= f.label :password, "パスワード", class: "text-sm font-medium text-slate-700" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-slate-500">最低 <%= @minimum_password_length %> 文字</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-slate-400" %>
    </div>

    <div class="space-y-2">
      <%= f.label :password_confirmation, "パスワード確認", class: "text-sm font-medium text-slate-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-slate-400" %>
    </div>

    <div class="pt-2">
      <%= f.submit "アカウントを作成", class: "inline-flex w-full items-center justify-center rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" %>
    </div>
  <% end %>

  <div class="mt-6 text-sm text-slate-600">
    <%= render "devise/shared/links" %>
  </div>
</section>
